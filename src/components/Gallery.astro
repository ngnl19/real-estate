---
import { Image } from "astro:assets";
import gallery1 from "../assets/images/gallery1.png";
import gallery2 from "../assets/images/gallery2.png";
import gallery3 from "../assets/images/gallery3.png";
import gallery4 from "../assets/images/gallery4.png";
import gallery5 from "../assets/images/gallery5.png";
import gallery6 from "../assets/images/gallery6.png";
import gallery7 from "../assets/images/gallery7.png";
import gallery8 from "../assets/images/gallery8.png";

const images = [
  {
    src: gallery1,
    alt: "House 1",
  },
  {
    src: gallery2,
    alt: "House 2",
  },
  {
    src: gallery3,
    alt: "House 3",
  },
  {
    src: gallery4,
    alt: "House 4",
  },
  {
    src: gallery5,
    alt: "House 5",
  },
  {
    src: gallery6,
    alt: "House 6",
  },
  {
    src: gallery7,
    alt: "House 7",
  },
  {
    src: gallery8,
    alt: "House 8",
  },
];
---

<section class="relative contain-content z-30 bg-bg py-16 md:py-24 opacity-0 translate-y-3 animate-[fadeIn_0.6s_forwards] transition-transform duration-300 scroll-mt-10" id="gallery">
  <div class="max-w-7xl mx-auto px-4 md:px-8">

    <div class="text-center mb-12 md:mb-20">
      <h2 class="font-heading text-3xl md:text-4xl text-primary mb-4">
        Property Showcase
      </h2>
      <p class="text-muted max-w-2xl mx-auto text-base md:text-lg">
        A glimpse into thoughtfully designed spaces, curated for modern living.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">

        {images.map((img, i) => (
          <div class="overflow-hidden rounded-2xl group">
            <div class="relative h-64 bg-gray-200 rounded-2xl skeleton-wrapper">

              <div class="skeleton-shimmer absolute inset-0 rounded-2xl" />

              <Image
                src={img.src}
                alt={img.alt}
                loading={i < 4 ? "eager" : "lazy"}
                fetchpriority={i < 4 ? "high" : "auto"}
                decoding={i < 4 ? "sync" : "async"}
                format="webp"
                sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 25vw"
                class="skeleton-image w-full h-64 object-cover rounded-2xl transition duration-500 group-hover:scale-[1.02] transform-gpu will-change-transform opacity-0"
                width="1000"
                height="800"
                onload="this.classList.add('loaded')"
              />
            </div>
          </div>
        ))}

      <style>
        .skeleton-shimmer {
          background: linear-gradient(
            90deg,
            transparent 0%,
            rgba(255,255,255,0.4) 50%,
            transparent 100%
          );
          background-size: 200% 100%;
          animation: shimmer 1.4s infinite;
        }

        @keyframes shimmer {
          0%   { background-position: -200% 0; }
          100% { background-position:  200% 0; }
        }

        .skeleton-image.loaded {
          opacity: 1;
          transition: opacity 0.4s ease;
        }

        .skeleton-image.loaded ~ .skeleton-shimmer,
        .skeleton-wrapper:has(.loaded) .skeleton-shimmer {
          display: none;
        }
      </style>

    </div>
    <div></div>
  </div>
</section>