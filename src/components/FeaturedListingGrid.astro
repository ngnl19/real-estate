---
import ListingCard from "./ListingCard.astro";
import ListingGrid from "./ListingGrid.astro";
import ListingNavbar from "./ListingNavbar.astro";
import { listings } from "../data/listing";

const {isVisible = true} = Astro.props;

---


<ListingNavbar show={isVisible ? false : true}/>

<section class="relative z-30 bg-bg py-16 md:py-24 opacity-0 translate-y-3 animate-[fadeIn_0.6s_forwards] transition-transform duration-300 scroll-mt-10" id="listings">
  <div class="max-w-7xl mx-auto px-4 md:px-8">

    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-4xl font-heading text-primary mb-4">
        Featured Listings
      </h2>
      <p class="text-muted max-w-2xl mx-auto">
        Explore our handpicked properties offering the best in comfort, style, and location.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-10">

      {listings.slice(0, 3).map(item => (
        <ListingCard {...item} />
      ))}

    </div>

    <div class={isVisible ? 'text-center mt-12' : 'hidden'}>
      <a href="/AllListings" class="inline-block bg-primary text-white 
      px-6 py-3 rounded-xl hover:bg-primary-dark transition-colors duration-300 font-semibold">
        View All Listings
      </a>
    </div>

  </div>
</section>

<ListingGrid display={isVisible ? false : true}/>