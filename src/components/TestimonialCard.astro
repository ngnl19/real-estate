---
import { Image } from "astro:assets";

const { name, role, image, text, rating = 5, variant = "center" } = Astro.props;

const scale =
  variant === "center"
    ? "scale-100 opacity-100 z-20"
    : "scale-90 opacity-60 z-10";

const size = variant === "center" ? "w-28 h-28" : "w-20 h-20";

const width =
  variant === "center"
    ? "w-80 md:w-96"
    : "w-64 md:w-72";
---

<div class={`bg-white rounded-2xl shadow-lg p-6 flex flex-col items-center text-center transition-all duration-300 ${scale} ${width}`}>
    <Image
    src={image}
    alt={name}
    loading="lazy"
    decoding="async"
    format="webp"
    class={`${size} rounded-full object-cover shadow-lg border-4 border-white`}
    width="400"
    height="400"/>

    <h3 class="mt-4 font-heading text-lg text-primary">{name}</h3>

    <p class="text-sm text-muted">{role}</p>

    <div class="flex mt-2 text-accent">
        {Array.from({ length: rating }).map(() => (
            <span class="material-symbols-outlined text-sm">
            star
            </span>
        ))}
    </div>

    <p class="mt-3 text-sm text-muted max-w-xs">{text}</p>
</div>