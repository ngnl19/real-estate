---
const { title, description, icon } = Astro.props;
---

<div
  class="group bg-white rounded-2xl p-6 shadow-sm hover:shadow-lg transition duration-300 hover:-translate-y-1">

  <div class="mb-4 text-accent">
    <span class="material-symbols-outlined text-3xl">
      {icon}
    </span>
  </div>

  <h3 class="font-heading text-xl text-primary mb-2">
    {title}
  </h3>

  <p class="text-muted text-sm md:text-base leading-relaxed">
    {description}
  </p>
</div>