---
import ListingCard from "./ListingCard.astro";
import { listings } from "../data/listing";

const { display } = Astro.props;
---

<section class={display ? 'relative z-30 bg-bg py-16 md:py-24 opacity-0 translate-y-3 animate-[fadeIn_0.6s_forwards] duration-300' : 'hidden'}>
  <div class="max-w-7xl mx-auto px-4 md:px-8">

    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-4xl font-heading text-primary mb-4">
        All Listings
      </h2>
      <p class="text-muted max-w-2xl mx-auto">
        Browse our complete collection of properties tailored to different lifestyles and budgets.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-10">
      {listings.map(item => (
        <ListingCard {...item} />
      ))}
    </div>

  </div>
</section>