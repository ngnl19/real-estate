---
import HeroImage from '../assets/images/hero.png'
---

<section class="relative z-40 h-screen flex items-center bg-cover bg-center overflow-hidden opacity-0 translate-y-3 animate-[fadeIn_0.6s_forwards] transition-transform duration-300 scroll-mt-10" style=`background-image: url(${HeroImage}');` id="home">
  <div class="absolute inset-0 bg-black/50 z-10 pointer-events-none"></div>

  <div class="relative container mx-auto px-6 text-center z-30">
    
    <h1 class="text-4xl md:text-6xl font-bold text-white mb-4">
      Find Your Dream Home with Confidence
    </h1>

    <p class="text-lg md:text-2xl text-white mb-8">
      Premium properties, expert guidance, and a seamless buying experience.
    </p>

    <div class="flex flex-wrap justify-center items-center gap-6 md:gap-10 mb-15 text-white font-bold">
      
      <div class="flex items-center gap-2">
        <span class="material-symbols-outlined text-accent text-2xl">home</span>
        <span class="text-sm md:text-lg">500+ Homes Sold</span>
      </div>

      <div class="flex items-center gap-2">
        <span class="material-symbols-outlined text-accent text-2xl">schedule</span>
        <span class="text-sm md:text-lg">10+ Years Experience</span>
      </div>

      <div class="flex items-center gap-2">
        <span class="material-symbols-outlined text-accent text-2xl">sentiment_satisfied</span>
        <span class="text-sm md:text-lg">98% Client Satisfaction</span>
      </div>

      <div class="flex items-center gap-2">
        <span class="material-symbols-outlined text-accent text-2xl">groups</span>
        <span class="text-sm md:text-base">Trusted by 1,000+ Clients</span>
      </div>

    </div>

    <!-- CTA -->
    <a href="#gallery" class="inline-block bg-primary hover:bg-primary-dark text-white px-6 py-3 rounded-full text-lg font-semibold transition-colors duration-300">
      Browse Properties
    </a>

  </div>
</section>