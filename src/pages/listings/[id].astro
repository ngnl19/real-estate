---
import { Image } from "astro:assets";
import { listings } from '../../data/listing';
import Layout from '../../layouts/Layout.astro';
import Footer from '../../components/Footer.astro';

export function getStaticPaths() {
  return listings.map(item => ({
    params: { id: item.id },
    props: { item }
  }));
}

const { item } = Astro.props;
---

<Layout>
  <section class="relative z-30 bg-background py-16 md:py-24 opacity-0 translate-y-3 animate-[fadeIn_0.6s_forwards] transition-transform duration-300">
    
    <div class="max-w-6xl mx-auto px-4">

      <div class="grid grid-cols-1 gap-8 mb-12">

        <div class="relative group">
          <Image
            src={item.image}
            alt={item.alt}
            width="1000"
            height="800"
            loading="eager"
            format="webp"
            class="w-full h-62.5 sm:h-87.5 lg:h-100 object-cover shadow-md rounded-2xl"
          />

          {item.tag && (
            <span class="absolute top-4 left-4 bg-accent text-white text-md px-3 py-1 rounded-full shadow">
              {item.tag}
            </span>
          )}
        </div>

        <div class="flex flex-col h-full">

          <div class="mt-auto mb-1">
            <h1 class="text-3xl sm:text-4xl font-heading text-primary mb-2">
              {item.price}
            </h1>

            <p class="text-muted mb-6">{item.address}</p>

            <div class="flex gap-6 text-gray-600 mb-8">

              <div class="flex items-center gap-2">
                <span class="material-symbols-outlined">bed</span>
                <span>{item.beds} Beds</span>
              </div>

              <div class="flex items-center gap-2">
                <span class="material-symbols-outlined">bathtub</span>
                <span>{item.baths} Baths</span>
              </div>

              <div class="flex items-center gap-2">
                <span class="material-symbols-outlined">straighten</span>
                <span>{item.sqft} sqft</span>
              </div>

            </div>
          </div>

        </div>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 mb-6">

        <div class="lg:col-span-2">
          <h2 class="text-2xl font-heading text-primary mb-4">
            Property Description
          </h2>

          <p class="text-muted leading-relaxed">
            {item.description}
          </p>
        </div>

        <div class="bg-white rounded-2xl shadow-md hover:shadow-xl transition duration-300 p-6 h-fit lg:-mt-24">

          <h3 class="text-xl flex justify-center font-heading text-primary mb-4">
            Agent Details
          </h3>

          <div class="flex justify-center gap-4 mb-4">
            <Image
              src={item.agentPicture}
              alt={item.alt}
              width="400"
              height="400"
              loading="eager"
              format="webp"
              class="w-28 h-28 rounded-full object-cover shadow-lg border-4 border-white"
            />
          </div>

          <div class="space-y-3 text-sm text-gray-700">
            <p><span class="font-semibold">Name:</span> {item.agent}</p>

            <p>
              <span class="font-semibold">Email:</span>
              <a href={`mailto:${item.email}`} class="text-accent ml-1 hover:underline">
                {item.email}
              </a>
            </p>

            <p>
              <span class="font-semibold">Contact:</span> {item.contact}
            </p>
          </div>

          <a
            href={`mailto:${item.email}`}
            target="_blank"
            class="block mt-6 text-center bg-accent text-white py-2 rounded-xl hover:bg-accent-dark transition"
          >
            Send Email
          </a>

        </div>

      </div>

    </div>
  </section>

  <Footer />
</Layout>